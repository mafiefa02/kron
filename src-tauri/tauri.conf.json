{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kron",
  "version": "0.2.0",
  "identifier": "com.mafiefa.kron",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": -100, "y": -100 },
        "width": 800,
        "minWidth": 800,
        "height": 600,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:kron.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBQ0NEMzE2RUY2RjMxRTYKUldUbU1XL3ZGdFBNMmtIMTRZQnhtbWNoUEVrL0pBTWVUVDdoU0tadFdqWU80ZnZhWTZ3TWc0RjEK",
      "endpoints": [
        "https://github.com/mafiefa02/kron/releases/latest/download/latest.json"
      ]
    }
  }
}
